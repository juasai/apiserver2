<h1>Carrito</h1>

{{#if cart.products.length}}
    <table>
        <thead>
            <tr>
                <th>Producto</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            {{#each cart.products}}
            <tr>
                <td>{{this.product.title}}</td>
                <td>{{this.product.description}}</td>
                <td>${{this.product.price}}</td>
                <td>{{this.quantity}}</td>
                <td>${{multiply this.product.price this.quantity}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
{{else}}
    <p>El carrito está vacío.</p>
{{/if}}

<a href="/products"><button type="button" style="margin-top: 15px;">Seguir comprando</button></a>
