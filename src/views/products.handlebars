<h1>Productos</h1>

<div class="filters">
    <form method="GET" action="/products">
        <label>Categoría:
            <input type="text" name="query" value="{{query}}" placeholder="Ej: Electronics">
        </label>
        <label>Disponibilidad:
            <select name="status">
                <option value="">Todas</option>
                <option value="true" {{#if statusTrue}}selected{{/if}}>Disponible</option>
                <option value="false" {{#if statusFalse}}selected{{/if}}>No disponible</option>
            </select>
        </label>
        <label>Ordenar por precio:
            <select name="sort">
                <option value="">Sin orden</option>
                <option value="asc" {{#if sortAsc}}selected{{/if}}>Ascendente</option>
                <option value="desc" {{#if sortDesc}}selected{{/if}}>Descendente</option>
            </select>
        </label>
        <label>Por página:
            <input type="number" name="limit" value="{{limit}}" min="1" max="50" style="width:60px">
        </label>
        <button type="submit">Filtrar</button>
    </form>
</div>

{{#if products.length}}
    <table>
        <thead>
            <tr>
                <th>Título</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Categoría</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>
            {{#each products}}
            <tr>
                <td><a href="/products/{{this._id}}">{{this.title}}</a></td>
                <td>{{this.description}}</td>
                <td>${{this.price}}</td>
                <td>{{this.stock}}</td>
                <td>{{this.category}}</td>
                <td>
                    <button onclick="addToCart('{{this._id}}')">Agregar al carrito</button>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="pagination">
        {{#if hasPrevPage}}
            <a href="{{prevLink}}"><button>Anterior</button></a>
        {{else}}
            <button disabled>Anterior</button>
        {{/if}}

        <span>Página {{page}} de {{totalPages}}</span>

        {{#if hasNextPage}}
            <a href="{{nextLink}}"><button>Siguiente</button></a>
        {{else}}
            <button disabled>Siguiente</button>
        {{/if}}
    </div>
{{else}}
    <p>No hay productos disponibles.</p>
{{/if}}

<style>
    .filters {
        background: #f9f9f9;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    .filters form {
        display: flex;
        gap: 15px;
        align-items: end;
        flex-wrap: wrap;
    }
    .filters label {
        display: flex;
        flex-direction: column;
        font-size: 14px;
    }
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        margin-top: 20px;
        padding: 15px;
    }
    .pagination a {
        text-decoration: none;
    }
</style>

<script>
    const CART_ID = localStorage.getItem('cartId');

    async function addToCart(productId) {
        let cartId = CART_ID;
        if (!cartId) {
            const res = await fetch('/api/carts', { method: 'POST' });
            const data = await res.json();
            cartId = data.data._id;
            localStorage.setItem('cartId', cartId);
        }

        const res = await fetch(`/api/carts/${cartId}/product/${productId}`, { method: 'POST' });
        if (res.ok) {
            alert('Producto agregado al carrito');
        } else {
            alert('Error al agregar al carrito');
        }
    }
</script>
